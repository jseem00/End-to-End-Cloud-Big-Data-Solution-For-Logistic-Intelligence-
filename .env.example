# Cloud Provider Configuration (Choose one: aws, azure, gcp)
CLOUD_PROVIDER=aws

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=logistics-raw-data
AWS_EMR_CLUSTER_ID=j-XXXXXXXXXXXXX

# Azure Configuration
AZURE_STORAGE_ACCOUNT=logisticsstorage
AZURE_STORAGE_KEY=your_azure_storage_key_here
AZURE_CONTAINER_NAME=raw-data
AZURE_RESOURCE_GROUP=logistics-rg

# GCP Configuration
GCP_PROJECT_ID=logistics-intelligence
GCP_BUCKET_NAME=logistics-raw-data
GCP_SERVICE_ACCOUNT_FILE=./credentials/service-account.json
GCP_DATAPROC_CLUSTER=logistics-cluster
GCP_REGION=us-central1

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOGISTICS=logistics-events
KAFKA_TOPIC_TELEMETRY=vehicle-telemetry
KAFKA_CONSUMER_GROUP=logistics-consumer-group

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistics_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here

# Airflow Configuration
AIRFLOW_HOME=~/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow

# External APIs (Optional)
OPENWEATHER_API_KEY=your_openweather_api_key
CURRENCY_API_KEY=your_currency_api_key

# Monitoring
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090

# Email Alerts
ALERT_EMAIL=alerts@logistics.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Application Settings
LOG_LEVEL=INFO
DEBUG_MODE=False
DATA_RETENTION_DAYS=90
